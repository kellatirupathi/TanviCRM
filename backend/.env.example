# ── TanviCRM Backend Environment ──────────────────────────────
# Copy this file to `.env` and adjust values for your environment.

# Server
PORT=5000
NODE_ENV=development

# Frontend origin(s) allowed by CORS (comma-separated for multiple).
# In production set this to your Vercel URL, e.g.
#   CLIENT_ORIGIN=https://tanvicrm.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# Set to "true" to also allow Vercel preview deployments (*.vercel.app).
ALLOW_VERCEL_PREVIEWS=false

# ── Supabase (primary database) ──────────────────────────────
# From your Supabase project → Settings → API
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# service_role secret key (server-only — NEVER expose to the frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── MongoDB (source, only needed for the one-time data migration) ──
# Used by `npm run migrate:mongo` to copy existing Atlas data into Supabase.
# Safe to remove once migration is done.
MONGO_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/tanvicrm

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-string
JWT_EXPIRES_IN=7d

# Seed admin (used by the seed script)
SEED_ADMIN_EMAIL=admin@tanviboutique.in
SEED_ADMIN_PASSWORD=Admin@123
