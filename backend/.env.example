# ── TanviCRM Backend Environment ──────────────────────────────
# Copy this file to `.env` and adjust values for your environment.

# Server
PORT=5000
NODE_ENV=development

# Frontend origin allowed by CORS (comma-separated for multiple)
CLIENT_ORIGIN=http://localhost:5173

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/tanvicrm

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-string
JWT_EXPIRES_IN=7d

# Seed admin (used by the seed script)
SEED_ADMIN_EMAIL=admin@tanviboutique.in
SEED_ADMIN_PASSWORD=Admin@123
